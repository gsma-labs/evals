/usr/share/openvswitch/scripts/ovs-ctl --system-id=random start
ovs-vsctl add-br leaf_4
ovs-vsctl set-fail-mode leaf_4 secure
ovs-vsctl set bridge leaf_4 stp_enable=true
ovs-vsctl add-port leaf_4 eth0
ip link set eth0 up
ovs-vsctl add-port leaf_4 eth1
ip link set eth1 up
ovs-vsctl add-port leaf_4 eth2
ip link set eth2 up
ovs-vsctl add-port leaf_4 eth3
ip link set eth3 up
ovs-vsctl add-port leaf_4 eth4
ovs-vsctl add-port leaf_4 eth5
ip addr add 20.0.0.6/24 dev eth6
ip link set eth6 up
ovs-vsctl set-controller leaf_4 tcp:20.0.0.100:6633
ovs-vsctl set bridge leaf_4 stp_enable=true