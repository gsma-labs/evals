/usr/share/openvswitch/scripts/ovs-ctl --system-id=random start
ovs-vsctl add-br spine_3
ovs-vsctl set-fail-mode spine_3 secure
ovs-vsctl set bridge spine_3 stp_enable=true
ovs-vsctl add-port spine_3 eth0
ovs-vsctl add-port spine_3 eth1
ovs-vsctl add-port spine_3 eth2
ovs-vsctl add-port spine_3 eth3
ovs-vsctl add-port spine_3 eth4
ovs-vsctl add-port spine_3 eth5
ovs-vsctl add-port spine_3 eth6
ovs-vsctl add-port spine_3 eth7
ip addr add 20.0.0.3/24 dev eth8
ip link set eth8 up
ovs-vsctl set-controller spine_3 tcp:20.0.0.100:6633
ovs-vsctl set bridge spine_3 stp_enable=true