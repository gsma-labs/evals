/usr/share/openvswitch/scripts/ovs-ctl --system-id=random start
ovs-vsctl add-br leaf_6
ovs-vsctl set-fail-mode leaf_6 secure
ovs-vsctl set bridge leaf_6 stp_enable=true
ovs-vsctl add-port leaf_6 eth0
ip link set eth0 up
ovs-vsctl add-port leaf_6 eth1
ip link set eth1 up
ovs-vsctl add-port leaf_6 eth2
ip link set eth2 up
ovs-vsctl add-port leaf_6 eth3
ip link set eth3 up
ovs-vsctl add-port leaf_6 eth4
ip link set eth4 up
ovs-vsctl add-port leaf_6 eth5
ip link set eth5 up
ovs-vsctl add-port leaf_6 eth6
ip link set eth6 up
ovs-vsctl add-port leaf_6 eth7
ip link set eth7 up
ovs-vsctl add-port leaf_6 eth8
ovs-vsctl add-port leaf_6 eth9
ovs-vsctl add-port leaf_6 eth10
ovs-vsctl add-port leaf_6 eth11
ip addr add 20.0.0.10/24 dev eth12
ip link set eth12 up
ovs-vsctl set-controller leaf_6 tcp:20.0.0.100:6633
ovs-vsctl set bridge leaf_6 stp_enable=true