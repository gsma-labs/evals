/usr/share/openvswitch/scripts/ovs-ctl --system-id=random start
ovs-vsctl add-br spine_1
ovs-vsctl set-fail-mode spine_1 secure
ovs-vsctl set bridge spine_1 stp_enable=true
ovs-vsctl add-port spine_1 eth0
ovs-vsctl add-port spine_1 eth1
ovs-vsctl add-port spine_1 eth2
ovs-vsctl add-port spine_1 eth3
ovs-vsctl add-port spine_1 eth4
ovs-vsctl add-port spine_1 eth5
ovs-vsctl add-port spine_1 eth6
ovs-vsctl add-port spine_1 eth7
ip addr add 20.0.0.1/24 dev eth8
ip link set eth8 up
ovs-vsctl set-controller spine_1 tcp:20.0.0.100:6633
ovs-vsctl set bridge spine_1 stp_enable=true