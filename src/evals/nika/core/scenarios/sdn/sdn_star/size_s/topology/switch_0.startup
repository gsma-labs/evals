/usr/share/openvswitch/scripts/ovs-ctl --system-id=random start
ovs-vsctl add-br switch_0
ovs-vsctl set-fail-mode switch_0 secure
ip link set eth0 up
ovs-vsctl add-port switch_0 eth0
ip link set eth1 up
ovs-vsctl add-port switch_0 eth1
ip link set eth2 up
ovs-vsctl add-port switch_0 eth2
ip link set eth3 up
ovs-vsctl add-port switch_0 eth3
ip addr add 20.0.0.1/24 dev eth4
ovs-vsctl set-controller switch_0 tcp:20.0.0.100:6633