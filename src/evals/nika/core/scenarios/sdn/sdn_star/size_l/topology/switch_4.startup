/usr/share/openvswitch/scripts/ovs-ctl --system-id=random start
ovs-vsctl add-br switch_4
ovs-vsctl set-fail-mode switch_4 secure
ovs-vsctl add-port switch_4 eth0
ip link set eth1 up
ovs-vsctl add-port switch_4 eth1
ip addr add 20.0.0.5/24 dev eth2
ovs-vsctl set-controller switch_4 tcp:20.0.0.100:6633