/usr/share/openvswitch/scripts/ovs-ctl --system-id=random start
ovs-vsctl add-br switch_7
ovs-vsctl set-fail-mode switch_7 secure
ovs-vsctl add-port switch_7 eth0
ip link set eth1 up
ovs-vsctl add-port switch_7 eth1
ip addr add 20.0.0.8/24 dev eth2
ovs-vsctl set-controller switch_7 tcp:20.0.0.100:6633