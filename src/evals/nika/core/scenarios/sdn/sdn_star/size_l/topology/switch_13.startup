/usr/share/openvswitch/scripts/ovs-ctl --system-id=random start
ovs-vsctl add-br switch_13
ovs-vsctl set-fail-mode switch_13 secure
ovs-vsctl add-port switch_13 eth0
ip link set eth1 up
ovs-vsctl add-port switch_13 eth1
ip addr add 20.0.0.14/24 dev eth2
ovs-vsctl set-controller switch_13 tcp:20.0.0.100:6633