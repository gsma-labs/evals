/usr/share/openvswitch/scripts/ovs-ctl --system-id=random start
ovs-vsctl add-br switch_10
ovs-vsctl set-fail-mode switch_10 secure
ovs-vsctl add-port switch_10 eth0
ip link set eth1 up
ovs-vsctl add-port switch_10 eth1
ip addr add 20.0.0.11/24 dev eth2
ovs-vsctl set-controller switch_10 tcp:20.0.0.100:6633